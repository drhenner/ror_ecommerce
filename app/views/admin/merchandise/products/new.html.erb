<%= render partial: '/admin/merchandise/sub_header' %>

<div class="page-header">
  <h1 class="page-title">New Product</h1>
</div>

<div class="card">
  <div class="card-body">
    <%= form_for @product, url: admin_merchandise_products_path, html: { class: '' } do |form| %>
      <%= render partial: 'form', locals: { form: form } %>
      <div class="form-group">
        <%= submit_tag "Create", class: "btn btn-primary", id: "create_product_button" %>
      </div>
    <% end %>
  </div>
</div>
