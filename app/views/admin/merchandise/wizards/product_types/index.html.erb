<%= render partial: '/admin/merchandise/wizards/sub_header' %>

<div class="page-header">
  <h1 class="page-title"><%= @product_types.empty? ? 'New Product Type' : 'Pick a Product Type' %></h1>
</div>

<div class="card mb-4">
  <div class="card-body">
    <div class="d-flex flex-wrap gap-3">
      <% @product_types.each do |product_type| %>
        <div class="card <%= 'selected' if selected?(product_type.id) %>" style="min-width: 150px;">
          <div class="card-body">
            <label class="form-label"><%= product_type.name %></label>
            <%= button_to 'Use', admin_merchandise_wizards_product_type_path(product_type),
                        class: "btn btn-outline btn-sm",
                        method: :put %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>

<div class="card">
  <div class="card-body">
    <%= form_for @product_type, url: admin_merchandise_wizards_product_types_path do |product_type_form| %>
      <%= render partial: 'form', locals: { form: product_type_form } %>
    <% end %>
  </div>
</div>
