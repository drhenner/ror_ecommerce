<%= render partial: '/admin/merchandise/wizards/sub_header' %>

<div class="page-header">
  <h1 class="page-title"><%= @shipping_categories.empty? ? 'New Shipping Category' : 'Pick a Shipping Category' %></h1>
</div>

<div class="card mb-4">
  <div class="card-body">
    <div class="d-flex flex-wrap gap-3">
      <% @shipping_categories.each do |shipping_category| %>
        <div class="card <%= selected?(shipping_category.id) %>" style="min-width: 150px;">
          <div class="card-body">
            <label class="form-label"><%= shipping_category.name %></label>
            <%= button_to 'Use', admin_merchandise_wizards_shipping_category_path(shipping_category),
                       class: "btn btn-outline btn-sm",
                       method: :put %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>

<div class="card">
  <div class="card-body">
    <%= form_for @shipping_category, url: admin_merchandise_wizards_shipping_categories_path do |shipping_category_form| %>
      <%= render partial: 'form', locals: { f: shipping_category_form } %>
    <% end %>
  </div>
</div>
