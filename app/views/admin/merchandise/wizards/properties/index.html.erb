<%= render partial: '/admin/merchandise/wizards/sub_header'%>

<div class="card mb-5">
  <div class="card-body">
    <% if @properties.empty? %>
      <h3>New Property</h3>
    <% else %>
      <h3>Pick a Property</h3>
    <% end %>

    <%= form_for @property, url: admin_merchandise_wizards_property_path(:id => 0), method: 'PUT' do |product_form| %>
      <div class="form-group">
        <%= select_tag 'property[ids][]',
                        options_from_collection_for_select(@properties, "id", "full_name", @selected),
                        :multiple => 'true',
                        :style => 'overflow:scroll; width: 350px; min-height: 120px',
                        'data-placeholder' => 'Choose Properties' %>
      </div>
      <%= product_form.submit 'Use Properties', class: 'btn btn-primary' %>
    <% end %>
  </div>
</div>

<% unless @properties.empty? %>
  <div class="card mb-5">
    <div class="card-header">
      <h3 class="card-title">New Property</h3>
    </div>
    <div class="card-body">
      <p class="text-muted">If the properties you want don't exist, create one now.</p>
      <%= form_for @property, url: admin_merchandise_wizards_properties_path do |property_form| %>
        <%= render partial: 'form', locals: { form: property_form } %>
      <% end %>
    </div>
  </div>
<% end %>

<% if @properties.empty? %>
  <%= form_for @property, url: admin_merchandise_wizards_properties_path do |property_form| %>
    <%= render partial: 'form', locals: { form: property_form } %>
  <% end %>
<% end %>

<% unless @prototypes.empty? %>
  <div class="card">
    <div class="card-header">
      <h3 class="card-title">New Prototype</h3>
    </div>
    <div class="card-body">
      <p class="text-muted mb-4">If you have a prototype created, select it here.</p>
      <div class="grid-2">
        <% @prototypes.each do |prototype| %>
          <div class="flex items-center justify-between p-3" style="border:1px solid var(--color-border);border-radius:var(--radius)">
            <span class="font-semibold"><%= prototype.name %></span>
            <%= button_to 'Use', admin_merchandise_wizards_prototype_path(prototype),
                          class: 'btn btn-outline btn-sm',
                          method: :put %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
