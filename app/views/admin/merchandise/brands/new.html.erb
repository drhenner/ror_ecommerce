<%= render partial: '/admin/merchandise/sub_header' %>

<div class="page-header">
  <h1 class="page-title">New Brand</h1>
</div>

<div class="card">
  <div class="card-body">
    <%= form_for @brand, url: admin_merchandise_brands_path(@brand) do |f| %>
      <%= render partial: 'form', locals: { f: f } %>
      <div class="form-group">
        <%= f.submit 'Create', class: 'btn btn-primary' %>
      </div>
    <% end %>
  </div>
</div>

<p class="mt-3">
  <%= link_to 'Back to List', admin_merchandise_brands_path, class: 'btn btn-outline' %>
</p>
