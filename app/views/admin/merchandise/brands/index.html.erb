<%= render partial: '/admin/merchandise/sub_header' %>

<div class="page-header">
  <h1 class="page-title">Brands</h1>
  <div class="page-actions">
    <%= link_to "New Brand", new_admin_merchandise_brand_path, class: "btn btn-primary" %>
  </div>
</div>

<div class="data-table">
  <table class="admin-table">
    <thead>
      <tr>
        <th>Name</th>
        <th></th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% for brand in @brands %>
        <tr>
          <td><%= link_to brand.name, admin_merchandise_brand_path(brand) %></td>
          <td><%= link_to "Edit", edit_admin_merchandise_brand_path(brand) %></td>
          <td><%= link_to "Delete", admin_merchandise_brand_path(brand), data: { turbo_confirm: 'Are you sure?', turbo_method: :delete }, class: "btn btn-danger btn-sm" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
