<%= render partial: '/admin/merchandise/sub_header' %>

<div class="page-header">
  <h1 class="page-title"><%= @product.name %></h1>
</div>

<div class="card">
  <div class="card-body">
    <%= form_for @product, url: admin_merchandise_multi_product_variant_path(@product), html: { class: '' }, data: { controller: "nested-form" } do |form| %>
      <div id='variants_container' class="d-flex flex-wrap gap-3">
        <%= render partial: '/admin/merchandise/multi/variants/form', locals: { form: form } %>
      </div>
      <div class="form-group d-flex gap-2 mt-3">
        <%= link_to "New Variant", "#", class: "btn btn-outline btn-sm", data: { association: "variants", action: "click->nested-form#add" } %>
        <%= submit_tag "Update", class: "btn btn-primary btn-sm", id: "update_product_button" %>
        <%= link_to 'Back to Product', admin_merchandise_product_path(@product), class: 'btn btn-outline btn-sm' %>
      </div>
    <% end %>
  </div>
</div>
