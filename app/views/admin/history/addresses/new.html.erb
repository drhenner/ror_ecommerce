<div class="page-header">
  <div>
    <h1 class="page-title">New Address for <%= @order.user.name %></h1>
  </div>
</div>

<div class="card">
  <div class="card-body">
    <%= form_for(@address, :url => admin_history_order_addresses_path(@order)) do |f| %>
      <%= render :partial => '/admin/history/addresses/form', :locals => {:f => f } %>
    <% end %>

    <%= link_to 'Back', admin_history_order_path(@order), class: 'btn btn-outline btn-sm mt-3' %>
  </div>
</div>
