<% content_for :sidebar_panel do %>
  <%= render partial: '/admin/shopping/right_panel_summary' %>
  <div class='admin_filters mt-3'>
    <%= form_tag admin_shopping_users_path, method: 'get', id: "shopping_users_search" do %>
      <p>
        <ul class=' search_boxes'>
          <li><%= label_tag 'first_name' %> <%= text_field_tag :first_name, params[:first_name] %></li>
          <li><%= label_tag 'last_name' %>  <%= text_field_tag :last_name, params[:last_name] %></li>
          <li><%= label_tag 'email' %> <%= text_field_tag :email, params[:email] %></li>
        </ul>
        <div class="d-flex justify-content-center">
          <%= submit_tag "Search", name: nil, class: 'btn btn-primary' %>
        </div>
      </p>
      <div id="users">
        <%= hidden_field_tag :direction, params[:direction] %>
        <%= hidden_field_tag :sort, params[:sort] %>
        <%== pagy_nav(@pagy) %>
      </div>
    <% end %>
  </div>
<% end %>

<div class="page-header">
  <div>
    <h1 class="page-title">Select User</h1>
  </div>
</div>

<div class="card">
  <div class="card-body">
    <div class="data-table">
      <table class="admin-table">
        <thead>
          <tr class='odd'>
            <th class='column1_header'><%= sortable "first_name" %></th>
            <th><%= sortable "last_name" %></th>
            <th><%= sortable "email" %></th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
        <% @users.each do |user| %>
          <tr class='<%= cycle("odd", "")%>'>
            <td><%= link_to user.first_name, admin_shopping_users_path(user_id: user.id), data: { turbo_method: :post } %></td>
            <td><%= user.last_name %></td>
            <td><%= user.email %></td>
            <td><%= user.state %></td>
          </tr>
        <% end %>
        </tbody>
      </table>
    </div>
    <%== pagy_nav(@pagy) %>
  </div>
</div>
<%= form_tag admin_shopping_users_path, id: 'admin-user-form' do %>
  <%= hidden_field_tag('user_id', nil, id: 'admin-user_id') %>
<% end %>
