<div class="page-header">
  <h1 class="page-title">Receive Purchase Order</h1>
</div>

<div class="card">
  <div class="card-body">
    <%= form_for @purchase_order, url: admin_inventory_receiving_path(@purchase_order) do |form| %>
      <div class="form-group flex items-center justify-between">
        <div>
          Invoice: <%= @purchase_order.invoice_number %>
          --- Tracking #: <%= @purchase_order.display_tracking_number %>
        </div>
        <div class="form-group mb-0">
          <%= form.check_box :receive_po %>
          <label class="form-label d-inline">Receive All</label>
        </div>
      </div>

      <%= form.fields_for :purchase_order_variants, @purchase_order.purchase_order_variants do |po_variant_form| %>
        <div>
          <%= render partial: 'form', locals: { po_variant_form: po_variant_form } %>
        </div>
      <% end %>

      <div class="form-group mt-4">
        <%= submit_tag "Update", class: "btn btn-primary", id: "create_purchase_order_button" %>
      </div>
    <% end %>
  </div>
</div>

<div class="mt-3">
  <%= link_to 'Back', admin_inventory_receivings_path, class: "btn btn-outline" %>
</div>
