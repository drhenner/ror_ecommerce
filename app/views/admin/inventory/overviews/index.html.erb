<div class="page-header">
  <h1 class="page-title">Product Overview</h1>
</div>

<div class="admin_inventory_overviews">
  <% @products.each do |product| %>
    <div class="card mb-4">
      <div class="card-header flex items-center justify-between">
        <h3 class="card-title mb-0"><%= product.name %></h3>
        <div class="flex gap-2">
          <%= link_to 'edit product', edit_admin_merchandise_product_path(product), class: 'btn btn-outline btn-sm' %>
          <%= link_to 'change inventory', admin_inventory_adjustment_path(product), class: 'btn btn-outline btn-sm' %>
        </div>
      </div>
      <div class="card-body">
        <div class="data-table">
          <table class="admin-table">
            <thead>
              <tr>
                <th>SKU</th>
                <th>price</th>
                <th>Qty</th>
                <th>description</th>
              </tr>
            </thead>
            <tbody>
              <% product.variants.each do |variant|%>
                <tr>
                  <td><%= variant.sku %></td>
                  <td><%= variant.price %></td>
                  <td><%= variant.count_on_hand %></td>
                  <td>
                    <ul class='vertical-list'>
                    <% variant.variant_properties.each do |vp| %>
                      <li><label><%= vp.property_name %>:</label> <%= vp.description %> </li>
                    <% end %>
                    </ul>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  <% end %>
</div>

<%== pagy_nav(@pagy) %>
