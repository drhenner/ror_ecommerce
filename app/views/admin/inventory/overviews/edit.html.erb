<div class="page-header">
  <h1 class="page-title">Edit Inventory (<%= @product.name %>)</h1>
</div>

<div class="card">
  <div class="card-body">
    <% if @product.errors.any? %>
      <div id="error_explanation">
        <h2><%= pluralize(@product.errors.count, "error") %> prohibited this product from being saved:</h2>
        <ul>
          <% @product.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>
    <%= form_for @product, url: admin_inventory_overview_path(@product) do |form| %>
      <%= render partial: '/admin/inventory/overviews/form', locals: { form: form } %>
      <div class="form-group mt-4">
        <%= form.submit "Update Inventory", class: "btn btn-primary", id: "edit_inventory_button" %>
      </div>
    <% end %>
  </div>
</div>
