<div class="page-header">
  <h1 class="page-title">New Purchase Order</h1>
</div>

<div class="card">
  <div class="card-body">
    <%= form_for @purchase_order, url: admin_inventory_purchase_orders_path, data: { controller: "nested-form variant-cost", variant_cost_url_value: "/admin/merchandise/products/0/variants" } do |form| %>
      <%= render partial: '/admin/inventory/purchase_orders/form', locals: { form: form } %>
      <div class="flex gap-2 mt-4">
        <%= submit_tag "Create", class: "btn btn-primary" %>
        <%= link_to 'Back', admin_inventory_purchase_orders_path, class: "btn btn-outline" %>
      </div>
    <% end %>
  </div>
</div>
