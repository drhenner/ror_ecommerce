<div class="page-header">
  <h1 class="page-title">Supplier: <%= @supplier.name %></h1>
</div>

<div class="card">
  <div class="card-body">
    <div class="form-group">
      <label class="form-label"><%= label :supplier, :name %></label>
      <div><%= @supplier.name %></div>
    </div>
    <div class="form-group">
      <label class="form-label"><%= label :supplier, :email %></label>
      <div><%= @supplier.email %></div>
    </div>
  </div>
</div>
