<div class="page-header">
  <div>
    <h1 class="page-title">Edit Coupon</h1>
  </div>
</div>

<div class="card">
  <div class="card-body">
    <%= form_for(@coupon, :as => :coupon, :url => admin_generic_coupon_path(@coupon)) do |f| %>
      <%= render :partial => 'form', :locals => {:f => f} %>
    <% end %>
    <div class="d-flex gap-2 mt-3">
      <%= link_to 'Show', admin_generic_coupon_path( @coupon ), :class => 'btn btn-outline btn-sm' %>
      <%= link_to 'View All', admin_generic_coupons_path, :class => 'btn btn-outline btn-sm' %>
    </div>
  </div>
</div>
