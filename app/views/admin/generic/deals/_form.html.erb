<%= render 'shared/error_messages', object: f.object %>
<div class="d-flex flex-wrap gap-4">
  <div class="flex-grow-1">
    <div class="form-group">
      <%= f.label :buy_quantity, class: 'form-label' %>
      <%= f.number_field :buy_quantity %>
    </div>
    <div class="form-group">
      <%= f.label :get_percentage, class: 'form-label' %>
      <%= f.number_field :get_percentage %>
    </div>
    <div class="form-group">
      <%= f.label :deal_type_id, 'Deal Type', class: 'form-label' %>
      <%= f.select :deal_type_id, deal_types, include_blank: true %>
    </div>
  </div>
  <div class="flex-grow-1">
    <div class="form-group">
      <%= f.label :product_type_id, class: 'form-label' %>
      <%= f.select :product_type_id, product_types, include_blank: true %>
    </div>
    <div class="form-group">
      <%= f.label :get_amount, class: 'form-label' %>
      <%= f.number_field :get_amount %>
    </div>
  </div>
</div>
