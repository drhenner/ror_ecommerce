<div class="page-header">
  <div>
    <h1 class="page-title"><%= customer.name.possessive %> Addresses</h1>
  </div>
  <div class="page-actions">
    <%= link_to "New Address", new_admin_user_datas_user_address_path(customer), class: 'btn btn-primary btn-sm' %>
  </div>
</div>

<div class="card">
  <div class="card-body">
    <div class="data-table">
      <table class="admin-table">
        <thead>
          <tr class='odd'>
            <th>Address</th>
            <th>Default</th>
            <th>Active</th>
            <th></th>
            <th></th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% for address in @addresses %>
            <tr class='<%= cycle("odd", "")%>'>
              <td>
                <%= render :partial => '/shared/compact_address', locals: { shopping_address: address} %>
              </td>
              <td><%= address.default %></td>
              <td><%= address.active %></td>
              <td><%= link_to 'View', [:admin, :user_datas, customer, address], class: 'btn btn-outline btn-sm' %></td>
              <td>
                <% if address.active %>
                  <%= link_to "edit", edit_admin_user_datas_user_address_path(customer, address), class: 'btn btn-outline btn-sm' %>
                <% end %>
              </td>
              <td>
                <% if address.active %>
                  <%= link_to "inactivate", [:admin, :user_datas, customer, address], data: { turbo_method: :delete, turbo_confirm: 'Are you sure?' }, class: 'btn btn-danger btn-sm' %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <%== pagy_nav(@pagy) %>
  </div>
</div>
