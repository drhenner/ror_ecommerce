<div class="page-header">
  <div>
    <h1 class="page-title">Edit <%= customer.name.possessive %> Address</h1>
  </div>
</div>

<div class="card">
  <div class="card-body">
    <%= form_for @form_address, url: admin_user_datas_user_address_path(customer,@form_address) do |f| %>
      <%= render partial: 'form', locals: { f: f } %>
      <div class="form-group"><%= f.submit 'Update', class: 'btn btn-primary' %></div>
    <% end %>
    <div class="d-flex gap-2 mt-3">
      <%= link_to "Show", admin_user_datas_user_address_path(customer, @form_address), class: 'btn btn-outline btn-sm' %> |
      <%= link_to "View All", admin_user_datas_user_addresses_path(customer), class: 'btn btn-outline btn-sm' %>
    </div>
  </div>
</div>
