<div class="page-header">
  <div>
    <h1 class="page-title"><%= customer.name.possessive %> Address</h1>
  </div>
</div>

<div class="card">
  <div class="card-body">
    <p>
      <%= render partial: '/shared/compact_address', locals: { shopping_address: @address } %>
    </p>

    <div class="d-flex gap-2 mt-3">
      <%= link_to "Show", admin_user_datas_user_address_path(customer, @address), class: 'btn btn-primary btn-sm' %> |
      <%= link_to "View All", admin_user_datas_user_addresses_path(customer), class: 'btn btn-outline btn-sm' %> |
      <%= link_to "Inactivate", admin_user_datas_user_address_path(customer, @address), data: { turbo_method: :delete, turbo_confirm: 'Are you sure?' }, class: 'btn btn-danger btn-sm' %>
    </div>
  </div>
</div>
