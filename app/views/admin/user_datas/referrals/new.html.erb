<div class="page-header">
  <h1 class="page-title">New Referral</h1>
  <div class="page-actions">
    <%= link_to "Back to List", admin_user_datas_referrals_path, class: 'btn btn-outline' %>
  </div>
</div>

<div class="card">
  <div class="card-body">
    <%= form_for @referral, url: admin_user_datas_referrals_path(@referral) do |f| %>
      <%= render partial: 'form', locals: { f: f } %>
      <div class="form-actions">
        <%= f.submit 'Create', class: 'btn btn-primary' %>
      </div>
    <% end %>
  </div>
</div>
