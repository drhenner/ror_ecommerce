<div class="page-header">
  <div>
    <h1 class="page-title">Referrals</h1>
  </div>
  <div class="page-actions">
    <%= link_to "Assign Referral", new_admin_user_datas_referral_path, class: 'btn btn-primary btn-sm' %>
    <%= link_to "Apply Referrals",
                apply_admin_user_datas_referral_path(0),
                data: { turbo_confirm: 'Are you sure?' },
                class: 'btn btn-danger btn-sm', method: 'POST' %>
  </div>
</div>

<div class="card">
  <div class="card-body">
    <div class="data-table">
      <table class="admin-table">
        <thead>
          <tr class='odd'>
            <th class='column1_header'><%= sortable 'name', 'Name' %></th>
            <th>Email</th>
            <th>Referring User</th>
            <th>Referral Program</th>
            <th>New User</th>
            <th>Referral Type</th>
            <th>Sent At</th>
            <th>Registered At</th>
            <th>Purchased At</th>
            <th>Applied</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
        <% for referral in @referrals %>
          <tr class='<%= cycle("odd", "")%>'>
            <td><%= link_to referral.name, [:admin, :user_datas, referral] %></td>
            <td><%= referral.email %></td>
            <td><%= referral.referring_user.name %></td>
            <td><%= referral.referral_program.name %></td>
            <td><%= referral.referral_user.try(:name) %></td>
            <td><%= referral.referral_type.name %></td>
            <td><%= referral.sent_at %></td>
            <td><%= referral.registered_at %></td>
            <td><%= referral.purchased_at %></td>
            <td><%= referral.applied %></td>
            <td><%= link_to "delete", [:admin, :user_datas, referral], data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: 'btn btn-danger btn-sm' %></td>
          </tr>
        <% end %>
        </tbody>
      </table>
    </div>
    <%== pagy_nav(@pagy) %>
  </div>
</div>
