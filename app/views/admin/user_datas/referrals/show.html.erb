<div class="page-header">
  <h1 class="page-title">Referral</h1>
  <div class="page-actions">
    <%= link_to "View All", admin_user_datas_referrals_path, class: 'btn btn-outline' %>
    <%= link_to "Destroy", [:admin, :user_datas, @referral], data: { turbo_confirm: "Are you sure?", turbo_method: :delete }, class: 'btn btn-danger' %>
  </div>
</div>

<div class="card">
  <div class="card-body">
    <ul class="vertical-list">
      <li><label>Name</label> <%= @referral.name %></li>
      <li><label>Email</label> <%= @referral.email %></li>
      <li><label>Referring User</label> <%= @referral.referring_user.try(:name) %></li>
      <li><label>Referral Program</label> <%= @referral.referral_program.name %></li>
      <li><label>Referral User</label> <%= @referral.referral_user.try(:name) || '-- Not signed up --' %></li>
      <li><label>Referral Type</label> <%= @referral.referral_type.try(:name) %></li>
      <li><label>Sent At</label> <%= @referral.sent_at %></li>
      <li><label>Registered At</label> <%= @referral.registered_at %></li>
      <li><label>Purchased At</label> <%= @referral.purchased_at %></li>
      <li><label>Applied</label> <%= @referral.applied %></li>
    </ul>
  </div>
</div>
