<div class="page-header">
  <div>
    <h1 class="page-title">Invoice for Order(<%= @invoice.order.number %>)</h1>
  </div>
</div>

<div class="card">
  <div class="card-body">
    <p>
      <strong>Amount:</strong>
      <%= @invoice.amount %>
    </p>

    <p>
      <strong>Status:</strong>
      <%= @invoice.state %>
    </p>

    <div class="d-flex gap-2 mt-3">
      <%= link_to "View PDF", admin_document_invoice_path(@invoice, :format => 'pdf'), :class => 'btn btn-primary btn-sm' %>
      <%= link_to "View All", admin_document_invoices_path, :class => 'btn btn-outline btn-sm' %>
    </div>
  </div>
</div>
