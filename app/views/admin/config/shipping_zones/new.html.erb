<div class="page-header">
  <h1 class="page-title">New Shipping Zone</h1>
  <div class="page-actions">
    <%= link_to 'Back', admin_config_shipping_zones_path, class: 'btn btn-outline' %>
  </div>
</div>

<div class="card">
  <div class="card-body">
    <%= form_for(@shipping_zone, url: admin_config_shipping_zones_path) do |f| %>
