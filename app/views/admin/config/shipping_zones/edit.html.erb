<div class="page-header">
  <h1 class="page-title">Editing Shipping Zone - <%= @shipping_zone.name %></h1>
  <div class="page-actions">
    <%= link_to "Back", admin_config_shipping_zones_path, class: 'btn btn-outline' %>
  </div>
</div>

<div class="card">
  <div class="card-body">
    <%= form_for(@shipping_zone, url: admin_config_shipping_zone_path(@shipping_zone)) do |f| %>
      <%= render partial: 'form', locals: { f: f } %>
    <% end %>
  </div>
</div>
