<div class="page-header">
  <h1 class="page-title">Shipping Zones</h1>
  <div class="page-actions">
    <%= link_to 'New Shipping Zone', new_admin_config_shipping_zone_path, class: 'btn btn-primary' %>
  </div>
</div>

<div class="card">
  <div class="card-body">
    <div class="data-table">
      <table class="admin-table">
        <thead>
          <tr>
            <th>Name</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @shipping_zones.each do |shipping_zone| %>
            <tr>
              <td><%= link_to shipping_zone.name, edit_admin_config_shipping_zone_path(shipping_zone) %></td>
              <td><%= link_to "Edit", edit_admin_config_shipping_zone_path(shipping_zone), class: 'btn btn-sm btn-outline' %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
