<% if @tax_rate.errors.any? %>
  <div id="error_explanation">
    <h2><%= pluralize(@tax_rate.errors.count, "error") %> prohibited this tax_rate from being saved:</h2>

    <ul>
    <% @tax_rate.errors.full_messages.each do |msg| %>
      <li><%= msg %></li>
    <% end %>
    </ul>
  </div>
<% end %>

<div class="form-group">
  <label class="form-label">Percentage</label>
  <%= f.text_field :percentage, class: "form-control" %>
</div>

<% if Settings.tax_per_state_id %>
  <div class="form-group">
    <label class="form-label">Country</label>
    <%= select_tag :select_country, options_from_collection_for_select(countries, "second", "first"), { include_blank: true, class: "form-control" } %>
  </div>
  <div class="form-group">
    <label class="form-label">State</label>
    <%= f.select :state_id, @states, { include_blank: true }, class: "form-control" %>
  </div>
<% else %>
  <div class="form-group">
    <label class="form-label">Country</label>
    <%= f.select :country_id, countries, { include_blank: true }, class: "form-control" %>
  </div>
<% end %>

<div class="form-group">
  <label class="form-label">Start Date</label>
  <div class="date-select">
    <%= f.date_select :start_date, { start_year: Time.zone.now.year, end_year: Time.zone.now.year + 12 } %>
  </div>
</div>

<div class="form-group">
  <label class="form-label">End Date</label>
  <div class="date-select">
    <%= f.date_select :end_date, { include_blank: true, start_year: Time.zone.now.year, end_year: Time.zone.now.year + 12 } %>
  </div>
</div>

<div class="form-group">
  <%= f.check_box :active %>
  <label class="form-label ml-2">Active</label>
</div>

<%= f.submit @tax_rate.new_record? ? "Create" : "Update", class: "btn btn-primary" %>
