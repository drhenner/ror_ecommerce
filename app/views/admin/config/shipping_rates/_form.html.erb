<% if @shipping_rate.errors.any? %>
  <div id="error_explanation">
    <h2><%= pluralize(@shipping_rate.errors.count, "error") %> prohibited this shipping_rate from being saved:</h2>

    <ul>
    <% @shipping_rate.errors.full_messages.each do |msg| %>
      <li><%= msg %></li>
    <% end %>
    </ul>
  </div>
<% end %>

<div class="form-group">
  <label class="form-label">Shipping Method</label>
  <%= f.select :shipping_method_id, @shipping_methods, {}, class: "form-control" %>
</div>

<div class="form-group">
  <label class="form-label">Rate</label>
  <%= f.text_field :rate, class: "form-control" %>
</div>

<div class="form-group">
  <label class="form-label">Minimum Charge</label>
  <%= f.text_field :minimum_charge, class: "form-control" %>
</div>

<div class="form-group">
  <label class="form-label">Shipping Rate Type</label>
  <%= f.select :shipping_rate_type_id, @shipping_rate_types, {}, class: "form-control" %>
</div>

<div class="form-group">
  <label class="form-label">Shipping Category</label>
  <%= f.select :shipping_category_id, @shipping_categories, {}, class: "form-control" %>
</div>

<%= f.submit @shipping_rate.new_record? ? "Create" : "Update", class: "btn btn-primary" %>
