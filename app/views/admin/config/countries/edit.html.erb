<div class="page-header">
  <h1 class="page-title">Edit <%= @country.name %></h1>
  <div class="page-actions">
    <%= link_to 'Back', admin_config_countries_path, class: 'btn btn-outline' %>
  </div>
</div>

<div class="card">
  <div class="card-body">
    <%= form_for(@country, url: admin_config_country_path(@country)) do |f| %>
      <%= render partial: 'form', locals: { f: f } %>
      <%= f.submit "Update", class: "btn btn-primary" %>
    <% end %>
  </div>
</div>
