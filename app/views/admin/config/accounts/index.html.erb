<div class="page-header">
  <h1 class="page-title">Listing Accounts</h1>
  <div class="page-actions">
    <%= link_to 'New Account', new_admin_config_account_path, class: 'btn btn-primary' %>
  </div>
</div>

<div class="card">
  <div class="card-body">
    <p>
      Accounts aren't really used in the app but in theory this is where you could assign each user monthly subscription charges.  If built out, this model could be associated to many variants through a account_variants table, or simply a charge for access to your cool site.
    </p>

    <div class="data-table">
      <table class="admin-table">
        <thead>
          <tr>
            <th>Account type</th>
            <th>Monthly charge</th>
            <th>Active</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @accounts.each do |account| %>
            <tr>
              <td><%= link_to account.account_type, edit_admin_config_account_path(account) %></td>
              <td><%= account.monthly_charge %></td>
              <td><%= account.active %></td>
              <td><%= link_to "Delete", admin_config_account_path(account), data: { turbo_method: :delete, turbo_confirm: 'Are you sure?' } %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
