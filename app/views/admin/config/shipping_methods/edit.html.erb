<div class="page-header">
  <h1 class="page-title">Edit Shipping Method</h1>
  <div class="page-actions">
    <%= link_to "Back", admin_config_shipping_methods_path, class: 'btn btn-outline' %>
  </div>
</div>

<div class="card">
  <div class="card-body">
    <%= form_for(@shipping_method, url: admin_config_shipping_method_path(@shipping_method)) do |f| %>
      <%= render partial: 'form', locals: { f: f } %>
    <% end %>
  </div>
</div>
