<div class="page-header">
  <h1 class="page-title">New User</h1>
</div>

<div class="card">
  <div class="card-body">
    <%= form_for @user, :url => admin_users_path(@user) do |form| %>
      <%= render partial: '/admin/users/form', locals: { form: form } %>
      <%= form.submit "Create", class: 'btn btn-primary' %>
    <% end %>
  </div>
</div>
