<div class="flex flex-wrap gap-4">
  <div class="card flex-1 min-w-0">
    <div class="card-header">
      <h3 class="card-title">RMA Details</h3>
    </div>
    <div class="card-body">
      <ul class="vertical-list">
        <li><label>Number</label><%= @return_authorization.number %></li>
        <li><label>Amount</label><%= number_to_currency @return_authorization.amount %></li>
        <li><label>Restocking Fee</label><%= number_to_currency @return_authorization.restocking_fee %></li>
        <li><label>State</label><span class="status-badge status-<%= @return_authorization.state %>"><%= @return_authorization.state %></span></li>
      </ul>

      <div class="line_item_blue mt-3">
        <% @return_authorization.return_items.each do |item| %>
          <div><%= item.order_item.variant.product_name %></div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="card flex-1 min-w-0">
    <div class="card-header">
      <h3 class="card-title">Order Details</h3>
    </div>
    <div class="card-body">
      <p><b>Order Number:</b> <%= @order.number %></p>
      <hr/>
      <b>Items</b>
      <div class="mt-2">
        <% @order.order_items.each do |item| %>
          <div class="flex justify-between mb-2">
            <span><%= item.variant.product_name %></span>
            <span><%= number_to_currency item.total %></span>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="card flex-1 min-w-0">
    <div class="card-body">
      <% if @return_authorization.authorized? %>
        <div class="flex gap-2">
          <%= link_to 'Cancel RMA',
                      edit_admin_rma_order_return_authorization_path(@order, @return_authorization),
                      class: 'btn btn-danger btn-sm',
                      data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to Cancel?" } %>
          <%= button_to 'Receive RMA',
                      complete_admin_rma_order_return_authorization_path(@order, @return_authorization),
                      class: 'btn btn-primary btn-sm',
                      data: { turbo_confirm: "Are you sure you want to Receive?" },
                      method: :put %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<div class="flex gap-3 mt-4">
  <% if @return_authorization.authorized? %>
    <%= link_to 'Edit RMA', edit_admin_rma_order_return_authorization_path(@order, @return_authorization), class: 'btn btn-outline btn-sm' %>
  <% end %>
  <%= link_to 'Order Info', admin_history_order_path(@order), class: 'btn btn-outline btn-sm' %>
  <%= link_to 'All RMAs for this Order', admin_rma_order_return_authorizations_path(@order), class: 'btn btn-outline btn-sm' %>
</div>
