<div class="page-header">
  <h1 class="page-title">Comments</h1>
  <div class="page-actions">
    <%= link_to "New Comment", new_admin_customer_service_user_comment_path(customer), class: 'btn btn-primary' %>
    <%= link_to "Back to #{customer.name}", admin_user_path(customer), class: 'btn btn-outline btn-sm' %>
  </div>
</div>

<div class="data-table">
  <table class="admin-table">
    <thead>
      <tr>
        <th><%= sortable 'note', 'Note' %></th>
        <th>Commentable Type</th>
        <th>Created By</th>
        <th>User</th>
      </tr>
    </thead>
    <tbody>
      <% for comment in @comments %>
        <tr>
          <td><%= link_to comment.note[0..100], [:admin, :customer_service, customer, comment] %></td>
          <td><%= comment.commentable_type %></td>
          <td><%= comment.author.try(:name) %></td>
          <td><%= comment.user.try(:name) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<%= will_paginate @comments %>
