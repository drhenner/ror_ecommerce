<div class="page-header">
  <h1 class="page-title">Edit Shipment</h1>
</div>

<div class="flex flex-wrap gap-4">
  <div class="card flex-1 min-w-0">
    <div class="card-header">
      <h3 class="card-title">Shipment Address</h3>
    </div>
    <div class="card-body">
      <%= render partial: '/shared/compact_address', locals: { shopping_address: @shipment.address } %>
      <%= link_to 'Change Address', edit_admin_fulfillment_shipment_address_path(@shipment, @shipment.address), class: "btn btn-outline btn-sm" %>
    </div>
  </div>

  <div class="card flex-1 min-w-0">
    <div class="card-header">
      <h3 class="card-title">Edit Shipment</h3>
    </div>
    <div class="card-body">
      <%= form_for(@shipment, url: admin_fulfillment_shipment_path(@shipment)) do |f| %>
        <%= render partial: 'form', locals: { f: f } %>
      <% end %>
    </div>
    <div class="card-body pt-0">
      <%= link_to 'Show', admin_fulfillment_shipment_path(@shipment), class: "btn btn-outline btn-sm" %>
      <%= link_to 'Back', admin_fulfillment_shipments_path(order_id: @shipment.order.number), class: "btn btn-outline btn-sm" %>
    </div>
  </div>

  <div class="card flex-1 min-w-0" data-controller="fulfillment-comment" data-fulfillment-comment-url-value="<%= admin_fulfillment_order_comments_path(@shipment.order) %>">
    <div class="card-header">
      <h3 class="card-title">Notes</h3>
    </div>
    <div class="card-body">
      <div id="order_comments">
        <ul data-fulfillment-comment-target="list">
          <% @shipment.order.comments.each do |comment| %>
            <li><%= comment.note %></li><hr/>
          <% end %>
        </ul>
      </div>

      <%= form_for(@comment, url: admin_fulfillment_order_comments_path(@shipment.order), data: { action: "submit->fulfillment-comment#submit" }) do |f| %>
        <%= render partial: 'comments_form', locals: { f: f } %>
      <% end %>
    </div>
  </div>
</div>
