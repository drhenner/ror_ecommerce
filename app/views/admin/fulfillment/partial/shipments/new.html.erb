<div class="page-header">
  <h1 class="page-title">Ship Order (<%= @order.number %>)</h1>
</div>

<div class="card">
  <div class="card-body">
    <%= form_for(@order, url: admin_fulfillment_partial_order_shipment_path(@order, 0)) do |f| %>
      <%= render partial: 'form', locals: { f: f } %>
    <% end %>
  </div>
</div>

<div class="flex gap-2 mt-4">
  <%= link_to "Order's Shipments", admin_fulfillment_shipments_path(order_id: @order.number), class: "btn btn-outline" %>
  <%= link_to "Back to Order", edit_admin_fulfillment_order_path(@order), class: "btn btn-outline" %>
</div>
