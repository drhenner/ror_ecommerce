<!DOCTYPE html>
<html lang="en">
<head>
  <title><%= site_name %> Admin</title>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <%= favicon_link_tag 'favicon.ico' %>

  <%= stylesheet_link_tag "admin_new", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
  <%= csrf_meta_tags %>
  <%= yield :head %>
</head>
<body class="admin-body" data-controller="sidebar">
  <div class="sidebar-overlay" data-sidebar-target="overlay" data-action="click->sidebar#close"></div>

  <nav class="admin-sidebar" data-sidebar-target="nav">
    <%= render "shared/admin/sidebar" %>
  </nav>

  <div class="main-wrapper">
    <header class="admin-topbar">
      <%= render "shared/admin/topbar" %>
    </header>

    <main class="main-content">
      <%= render "shared/admin/flash" %>

      <% if content_for?(:sidebar_panel) %>
        <div class="two-column-layout">
          <div><%= yield %></div>
          <aside class="sidebar-panel"><%= yield :sidebar_panel %></aside>
        </div>
      <% else %>
        <%= yield %>
      <% end %>
    </main>
  </div>

  <%= yield :bottom %>
</body>
</html>
