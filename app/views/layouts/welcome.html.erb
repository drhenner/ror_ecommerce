<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>
    <%= content_for?(:title) ? "#{site_name}: #{yield(:title)}" : site_name %>
  </title>
  <%= favicon_link_tag 'favicon.ico' %>
  <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
  <%= csrf_meta_tags %>
  <%= yield :head %>
  <%= render 'shared/metadata' %>
</head>
<body>
  <%= render partial: '/shared/welcome_header' %>

  <% if notice || alert || flash[:error] %>
    <div class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-6 py-3 text-sm font-medium shadow-md <%= (alert || flash[:error]) ? 'bg-red-50 text-red-800 border-b border-red-200' : 'bg-amber-50 text-amber-800 border-b border-amber-200' %>"
         role="alert"
         data-controller="flash">
      <span>
        <%= alert || flash[:error] || notice %>
      </span>
      <button type="button" class="ml-4 text-current opacity-60 hover:opacity-100 text-lg leading-none" data-action="flash#dismiss" aria-label="Close">
        &times;
      </button>
    </div>
  <% end %>

  <main class="pt-header">
    <%= yield %>
  </main>

  <%= render 'shared/main_footer' %>
  <%= render 'shared/google_analytics' unless @disable_ga %>
  <%= yield :bottom %>
  <%= yield :below_body %>
</body>
</html>
