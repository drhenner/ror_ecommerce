<%= form_for search_product, html: { class: 'flex items-center gap-2' } do %>
  <div class="relative flex-1">
    <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-[var(--color-text-light)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
    </svg>
    <%= text_field_tag 'q', nil, class: 'w-full border border-[var(--color-border)] pl-10 pr-3 py-2 text-sm', id: 'term', placeholder: 'Search products...' %>
  </div>
  <%= submit_tag 'Search', class: 'btn btn-dark text-xs py-2 px-4' %>
<% end %>
