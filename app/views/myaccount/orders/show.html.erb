<h3 class="text-xl font-medium mb-6">Order # <%= @order.number %></h3>

<div class="bg-[var(--color-surface)] border border-[var(--color-border)] overflow-hidden">
  <table class="w-full text-sm">
    <tbody>
      <tr class="border-b border-[var(--color-border)]">
        <td class="px-4 py-3 text-[var(--color-text-muted)] font-medium w-40">Number</td>
        <td class="px-4 py-3"><%= @order.number %></td>
      </tr>
      <tr class="border-b border-[var(--color-border)]">
        <td class="px-4 py-3 text-[var(--color-text-muted)] font-medium">Completed at</td>
        <td class="px-4 py-3"><%= @order.display_completed_at %></td>
      </tr>
      <tr class="border-b border-[var(--color-border)]">
        <td class="px-4 py-3 text-[var(--color-text-muted)] font-medium align-top">Shipping Address</td>
        <td class="px-4 py-3">
          <% if @order.ship_address_id %>
            <%= render partial: '/shared/compact_address', locals: { shopping_address: @order.ship_address } %>
          <% end %>
        </td>
      </tr>
      <tr class="border-b border-[var(--color-border)]">
        <td class="px-4 py-3 text-[var(--color-text-muted)] font-medium align-top">Billing Address</td>
        <td class="px-4 py-3">
          <% if @order.bill_address_id %>
            <%= render partial: '/shared/compact_address', locals: { shopping_address: @order.bill_address } %>
          <% end %>
        </td>
      </tr>
      <tr>
        <td class="px-4 py-3 font-semibold align-top" colspan="2">Items</td>
      </tr>
      <% @order.order_items.each do |item| %>
        <tr class="border-t border-[var(--color-border)]/50">
          <td class="px-4 py-2" colspan="2">
            <% if item.variant&.product %>
              <%= link_to item.variant.product_name, product_path(item.variant.product), class: "text-[var(--color-accent)] hover:underline" %>
            <% else %>
              <span class="text-[var(--color-text-muted)]">Product no longer available</span>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
