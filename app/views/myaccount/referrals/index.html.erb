<h3 class="text-xl font-medium mb-2">Invite a Friend</h3>
<p class="text-sm text-[var(--color-text-muted)] mb-6">
  Ready to get your friends aboard? Enter their information below:
</p>

<%= form_for @referral, url: myaccount_referrals_path do |f| %>
  <%= render partial: 'form', locals: { f: f } %>
  <div class="mt-4">
    <%= f.submit 'Invite', class: 'btn btn-dark' %>
  </div>
<% end %>

<% unless @referrals.empty? %>
  <div class="mt-10">
    <div class="bg-[var(--color-surface)] border border-[var(--color-border)] overflow-hidden">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-[var(--color-highlight)] border-b border-[var(--color-border)]">
            <th class="text-left px-4 py-3 font-medium">Name</th>
            <th class="text-left px-4 py-3 font-medium">Email</th>
            <th class="text-left px-4 py-3 font-medium">Status</th>
          </tr>
        </thead>
        <tbody>
          <% @referrals.each do |referral| %>
            <tr class="border-b border-[var(--color-border)]/50">
              <td class="px-4 py-3"><%= referral.name %></td>
              <td class="px-4 py-3 text-[var(--color-text-muted)]"><%= referral.email %></td>
              <td class="px-4 py-3 text-[var(--color-text-muted)]"><%= referral.display_status %> (<%= referral.display_formatted_status_date %>)</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% end %>
