<h3 class="text-xl font-medium mb-6">Address</h3>

<div class="text-sm text-[var(--color-text-muted)] leading-relaxed mb-6">
  <%= render partial: '/shared/compact_address', locals: { shopping_address: @address } %>
</div>

<div class="flex items-center gap-3">
  <%= link_to "Edit", edit_myaccount_address_path(@address), class: "btn btn-dark text-xs py-2 px-4" %>
  <%= link_to "Delete", myaccount_address_path(@address), data: { turbo_confirm: 'Are you sure?', turbo_method: :delete }, class: "text-xs text-[var(--color-sale)] hover:underline" %>
  <%= link_to "View All", myaccount_addresses_path, class: "text-xs text-[var(--color-accent)] hover:underline" %>
</div>
