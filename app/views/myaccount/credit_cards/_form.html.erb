<% if @credit_card.errors.any? %>
  <div class="bg-red-50 border border-red-200 text-red-800 px-5 py-4 mb-6 text-sm rounded">
    <h3 class="font-semibold mb-2"><%= pluralize(@credit_card.errors.count, "error") %> prohibited this credit card from being saved:</h3>
    <ul class="list-disc pl-5 space-y-1">
      <% @credit_card.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<div class="max-w-md space-y-4">
  <div>
    <%= f.label :card_name, "Card Name", class: 'block text-xs font-medium text-[var(--color-text-muted)] mb-1' %>
    <%= f.text_field :card_name, class: 'w-full border border-[var(--color-border)] px-3 py-2 text-sm' %>
  </div>
  <div>
    <%= f.submit 'Save', class: 'btn btn-dark' %>
  </div>
</div>
