<aside class="w-full md:w-56 shrink-0">
  <% if content_for? :account_title %>
    <h3 class="text-lg font-semibold mb-4"><%= yield :account_title %></h3>
  <% else %>
    <h3 class="text-lg font-semibold mb-4">Your Account</h3>
  <% end %>

  <nav>
    <ul class="space-y-1">
      <li>
        <%= link_to 'Addresses', myaccount_addresses_path,
            class: "block px-3 py-2 rounded text-sm transition-colors #{selected_myaccount_tab('address') ? 'bg-[var(--color-highlight)] text-[var(--color-text)] font-medium' : 'text-[var(--color-text-muted)] hover:bg-[var(--color-highlight)]'}" %>
      </li>
      <li>
        <%= link_to 'Credit Cards', myaccount_credit_cards_path,
            class: "block px-3 py-2 rounded text-sm transition-colors #{selected_myaccount_tab('credit_cards') ? 'bg-[var(--color-highlight)] text-[var(--color-text)] font-medium' : 'text-[var(--color-text-muted)] hover:bg-[var(--color-highlight)]'}" %>
      </li>
      <li>
        <%= link_to 'Orders', myaccount_orders_path,
            class: "block px-3 py-2 rounded text-sm transition-colors #{selected_myaccount_tab('orders') ? 'bg-[var(--color-highlight)] text-[var(--color-text)] font-medium' : 'text-[var(--color-text-muted)] hover:bg-[var(--color-highlight)]'}" %>
      </li>
      <li>
        <%= link_to 'Profile', myaccount_overview_path,
            class: "block px-3 py-2 rounded text-sm transition-colors #{selected_myaccount_tab('profile') ? 'bg-[var(--color-highlight)] text-[var(--color-text)] font-medium' : 'text-[var(--color-text-muted)] hover:bg-[var(--color-highlight)]'}" %>
      </li>
      <li>
        <%= link_to 'Referrals', myaccount_referrals_path,
            class: "block px-3 py-2 rounded text-sm transition-colors #{selected_myaccount_tab('referrals') ? 'bg-[var(--color-highlight)] text-[var(--color-text)] font-medium' : 'text-[var(--color-text-muted)] hover:bg-[var(--color-highlight)]'}" %>
      </li>
      <li>
        <%= link_to 'Store Credits', myaccount_store_credit_path,
            class: "block px-3 py-2 rounded text-sm transition-colors #{selected_myaccount_tab('store_credit') ? 'bg-[var(--color-highlight)] text-[var(--color-text)] font-medium' : 'text-[var(--color-text-muted)] hover:bg-[var(--color-highlight)]'}" %>
      </li>
    </ul>
  </nav>
</aside>
