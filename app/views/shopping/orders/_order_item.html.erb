<div class="flex gap-4 items-start">
  <div class="w-16 h-16 shrink-0 bg-[var(--color-highlight)] overflow-hidden">
    <%= image_tag(items.first.variant.product.featured_image(:mini),
                  alt: items.first.variant.product.name,
                  class: "w-full h-full object-cover") %>
  </div>
  <div class="flex-1">
    <p class="text-sm font-medium"><%= items.first.variant.product.name %></p>
    <p class="text-xs text-[var(--color-text-muted)] mt-1">Qty: <%= items.size %></p>
    <div class="text-xs text-[var(--color-text-muted)] mt-1">
      <%= sanitize items.first.variant.display_property_details %>
    </div>
  </div>
</div>
