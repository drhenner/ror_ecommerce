<div class="py-10">
  <h1 class="text-3xl font-normal mb-8" style="font-family: var(--font-display)">Order Summary</h1>

  <div class="flex flex-col lg:flex-row gap-10">
    <%# Left: items + addresses %>
    <div class="flex-1">
      <div class="space-y-4 mb-8">
        <% @order.order_items.group_by(&:variant_id).each_with_index do |(variant_id, items), i| %>
          <div class="bg-[var(--color-surface)] border border-[var(--color-border)] p-5">
            <%= render partial: 'order_item', locals: { items: items } %>
          </div>
        <% end %>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-[var(--color-surface)] border border-[var(--color-border)] p-5">
          <h3 class="text-sm font-semibold uppercase tracking-wider mb-3">Shipping Address</h3>
          <div class="text-sm text-[var(--color-text-muted)] leading-relaxed">
            <%= render partial: '/shared/compact_address', locals: { shopping_address: @order.ship_address } %>
          </div>
          <%= link_to 'Change', shopping_addresses_path, class: 'btn-link text-xs mt-3 inline-block' %>
        </div>
        <div class="bg-[var(--color-surface)] border border-[var(--color-border)] p-5">
          <h3 class="text-sm font-semibold uppercase tracking-wider mb-3">Billing Address</h3>
          <div class="text-sm text-[var(--color-text-muted)] leading-relaxed">
            <%= render partial: '/shared/compact_address', locals: { shopping_address: @order.bill_address } %>
          </div>
          <%= link_to 'Change', shopping_billing_addresses_path, class: 'btn-link text-xs mt-3 inline-block' %>
        </div>
      </div>
    </div>

    <%# Right: price summary + payment form %>
    <div class="w-full lg:w-96 shrink-0">
      <div class="bg-[var(--color-surface)] border border-[var(--color-border)] p-6 mb-6">
        <h3 class="text-sm font-semibold uppercase tracking-wider mb-4">Price Details</h3>
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-[var(--color-border)]">
              <th class="text-left py-2 font-medium">Item</th>
              <th class="text-right py-2 font-medium">Price</th>
              <th class="text-right py-2 font-medium">Total</th>
            </tr>
          </thead>
          <tbody>
            <% @order.order_items.each do |item| %>
              <tr class="border-b border-[var(--color-border)]/50">
                <td class="py-2 text-[var(--color-text-muted)]"><%= item.variant.product.name %></td>
                <td class="py-2 text-right"><%= number_to_currency item.price %></td>
                <td class="py-2 text-right"><%= number_to_currency item.total %></td>
              </tr>
            <% end %>
          </tbody>
          <tfoot class="text-sm">
            <tr class="border-t border-[var(--color-border)]">
              <td class="py-2" colspan="2">Subtotal</td>
              <td class="py-2 text-right"><%= number_to_currency @order.sub_total %></td>
            </tr>
            <tr>
              <td class="py-1 text-[var(--color-text-muted)]" colspan="2">Shipping</td>
              <td class="py-1 text-right"><%= number_to_currency @order.shipping_charges %></td>
            </tr>
            <% if @order.coupon_amount > 0.0 %>
              <tr>
                <td class="py-1 text-green-700" colspan="2">Coupon</td>
                <td class="py-1 text-right text-green-700">-<%= number_to_currency @order.coupon_amount %></td>
              </tr>
            <% end %>
            <% if @order.deal_amount && @order.deal_amount > 0.0 %>
              <tr>
                <td class="py-1 text-green-700" colspan="2">Promotion</td>
                <td class="py-1 text-right text-green-700">-<%= number_to_currency @order.deal_amount %></td>
              </tr>
            <% end %>
            <tr>
              <td class="py-1 text-[var(--color-text-muted)]" colspan="2">Tax</td>
              <td class="py-1 text-right"><%= number_to_currency @order.taxed_amount %></td>
            </tr>
            <% if @order.amount_to_credit && @order.amount_to_credit > 0.0 %>
              <tr>
                <td class="py-1 text-green-700" colspan="2">Credits</td>
                <td class="py-1 text-right text-green-700">-<%= number_to_currency @order.amount_to_credit %></td>
              </tr>
            <% end %>
            <tr class="border-t-2 border-[var(--color-text)] font-semibold text-base">
              <td class="pt-3" colspan="2">Total</td>
              <td class="pt-3 text-right"><%= number_to_currency @order.credited_total %></td>
            </tr>
          </tfoot>
        </table>
      </div>

      <div class="bg-[var(--color-surface)] border border-[var(--color-border)] p-6">
        <h3 class="text-sm font-semibold uppercase tracking-wider mb-4">Payment</h3>

        <%= form_tag(shopping_order_path(@order), method: :put, id: 'purchase_order') do %>
          <div class="space-y-4">
            <div class="grid grid-cols-2 gap-4">
              <div>
                <%= label_tag :first_name, 'First Name', class: 'block text-xs font-medium text-[var(--color-text-muted)] mb-1' %>
                <%= text_field_tag :first_name, @credit_card.first_name, class: 'w-full border border-[var(--color-border)] px-3 py-2 text-sm' %>
              </div>
              <div>
                <%= label_tag :last_name, 'Last Name', class: 'block text-xs font-medium text-[var(--color-text-muted)] mb-1' %>
                <%= text_field_tag :last_name, @credit_card.last_name, class: 'w-full border border-[var(--color-border)] px-3 py-2 text-sm' %>
              </div>
            </div>

            <div class="grid grid-cols-3 gap-4">
              <div class="col-span-2">
                <%= label_tag :number, 'Card Number', class: 'block text-xs font-medium text-[var(--color-text-muted)] mb-1' %>
                <%= text_field_tag :number, @credit_card.number, class: 'w-full border border-[var(--color-border)] px-3 py-2 text-sm disableAutoComplete', autocomplete: "off" %>
              </div>
              <div>
                <%= label_tag :verification_value, 'CVV', class: 'block text-xs font-medium text-[var(--color-text-muted)] mb-1' %>
                <%= text_field_tag :verification_value, @credit_card.verification_value, class: 'w-full border border-[var(--color-border)] px-3 py-2 text-sm disableAutoComplete', autocomplete: "off" %>
              </div>
            </div>

            <div>
              <%= label_tag :type, 'Card Type', class: 'block text-xs font-medium text-[var(--color-text-muted)] mb-1' %>
              <%= select_tag :type,
                  options_for_select(['visa', 'mastercard'], selected: @credit_card.type),
                  class: 'w-full border border-[var(--color-border)] px-3 py-2 text-sm bg-white' %>
            </div>

            <div class="grid grid-cols-2 gap-4">
              <div>
                <%= label_tag :month, 'Month', class: 'block text-xs font-medium text-[var(--color-text-muted)] mb-1' %>
                <%= select_tag :month,
                    options_for_select(['01','02','03','04','05','06','07','08','09','10','11','12'], selected: @credit_card.month),
                    class: 'w-full border border-[var(--color-border)] px-3 py-2 text-sm bg-white' %>
              </div>
              <div>
                <%= label_tag :year, 'Year', class: 'block text-xs font-medium text-[var(--color-text-muted)] mb-1' %>
                <%= select_tag :year,
                    options_for_select((Time.zone.now.year..(Time.zone.now.year + 10)), selected: @credit_card.year),
                    class: 'w-full border border-[var(--color-border)] px-3 py-2 text-sm bg-white' %>
              </div>
            </div>

            <%= submit_tag 'Complete Order', class: 'btn btn-dark w-full justify-center mt-2',
                data: { turbo_submits_with: 'Processing...' } %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
