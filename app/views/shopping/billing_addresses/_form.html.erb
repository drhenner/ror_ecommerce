<% if @shopping_address.errors.any? %>
  <div class="bg-red-50 border border-red-200 text-red-800 px-5 py-4 mb-6 text-sm rounded">
    <h3 class="font-semibold mb-2"><%= pluralize(@shopping_address.errors.count, "error") %> prohibited this address from being saved:</h3>
    <ul class="list-disc pl-5 space-y-1">
      <% @shopping_address.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<div class="max-w-2xl space-y-4">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <%= f.label :first_name, class: 'block text-xs font-medium text-[var(--color-text-muted)] mb-1' %>
      <%= f.text_field :first_name, class: 'w-full border border-[var(--color-border)] px-3 py-2 text-sm' %>
    </div>
    <div>
      <%= f.label :last_name, class: 'block text-xs font-medium text-[var(--color-text-muted)] mb-1' %>
      <%= f.text_field :last_name, class: 'w-full border border-[var(--color-border)] px-3 py-2 text-sm' %>
    </div>
  </div>

  <%= f.fields_for :phones do |phone_f| %>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <%= phone_f.label :display_number, 'Primary Phone', class: 'block text-xs font-medium text-[var(--color-text-muted)] mb-1' %>
        <%= phone_f.text_field :display_number, class: 'w-full border border-[var(--color-border)] px-3 py-2 text-sm' %>
      </div>
      <div>
        <%= phone_f.label :phone_type_id, 'Type', class: 'block text-xs font-medium text-[var(--color-text-muted)] mb-1' %>
        <%= phone_f.select :phone_type_id, phone_types, {},
            { class: 'w-full border border-[var(--color-border)] px-3 py-2 text-sm bg-white' } %>
      </div>
    </div>
  <% end %>

  <div>
    <%= f.label :address1, class: 'block text-xs font-medium text-[var(--color-text-muted)] mb-1' %>
    <%= f.text_field :address1, class: 'w-full border border-[var(--color-border)] px-3 py-2 text-sm' %>
  </div>

  <div>
    <%= f.label :address2, class: 'block text-xs font-medium text-[var(--color-text-muted)] mb-1' %>
    <%= f.text_field :address2, class: 'w-full border border-[var(--color-border)] px-3 py-2 text-sm' %>
  </div>

  <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
    <div class="col-span-2 md:col-span-1">
      <%= f.label :city, class: 'block text-xs font-medium text-[var(--color-text-muted)] mb-1' %>
      <%= f.text_field :city, class: 'w-full border border-[var(--color-border)] px-3 py-2 text-sm' %>
    </div>

    <% if Settings.require_state_in_address %>
      <div>
        <%= f.label :state_id, "State", class: 'block text-xs font-medium text-[var(--color-text-muted)] mb-1' %>
        <%= f.select :state_id, @states,
            { include_blank: true, prompt: "State" },
            { class: 'w-full border border-[var(--color-border)] px-3 py-2 text-sm bg-white' } %>
      </div>
    <% elsif countries.size == 1 %>
      <div>
        <%= f.label :country_id, "Country", class: 'block text-xs font-medium text-[var(--color-text-muted)] mb-1' %>
        <p class="text-sm py-2"><%= countries.first.name %></p>
        <%= f.hidden_field :country_id %>
      </div>
    <% else %>
      <div>
        <%= f.label :country_id, "Country", class: 'block text-xs font-medium text-[var(--color-text-muted)] mb-1' %>
        <%= f.select :country_id, select_countries,
            { include_blank: true },
            { class: 'w-full border border-[var(--color-border)] px-3 py-2 text-sm bg-white' } %>
      </div>
    <% end %>

    <div>
      <%= f.label :zip_code, class: 'block text-xs font-medium text-[var(--color-text-muted)] mb-1' %>
      <%= f.text_field :zip_code, class: 'w-full border border-[var(--color-border)] px-3 py-2 text-sm' %>
    </div>
  </div>

  <label class="flex items-center gap-2 text-sm cursor-pointer">
    <%= f.check_box :billing_default, class: 'accent-[var(--color-accent)]' %>
    Make this my default billing address
  </label>

  <div class="flex items-center gap-3 pt-2">
    <%= f.submit 'Save & Continue', class: 'btn btn-dark' %>
    <% unless current_page?(shopping_billing_addresses_path) %>
      <%= link_to 'Back', shopping_billing_addresses_path, class: 'btn btn-ghost text-[var(--color-text)] border-[var(--color-border)]' %>
    <% end %>
  </div>
</div>
