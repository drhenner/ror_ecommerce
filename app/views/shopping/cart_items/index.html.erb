<div class="py-10">
  <h1 class="text-3xl font-normal mb-8" style="font-family: var(--font-display)">Your Bag</h1>

  <% if @cart_items.blank? && @saved_cart_items.empty? %>
    <div class="text-center py-16">
      <p class="text-lg text-[var(--color-text-muted)]"><%= I18n.t(:nothing_in_cart) %></p>
      <%= link_to 'Continue Shopping', products_path, class: 'btn btn-dark mt-6 inline-flex' %>
    </div>
  <% elsif @cart_items.blank? %>
    <div class="text-center py-10 mb-8">
      <p class="text-lg text-[var(--color-text-muted)]"><%= I18n.t(:only_items_saved_for_later) %></p>
      <p class="bg-[var(--color-highlight)] border border-[var(--color-border)] px-6 py-4 mt-4 text-[var(--color-text-muted)] inline-block">
        <%= I18n.t(:add_items_saved_for_later) %>
      </p>
    </div>
  <% end %>

  <%= form_for session_cart, url: shopping_cart_item_path(session_cart), as: :cart do |cart_form| %>
    <% unless @cart_items.blank? %>
      <div class="flex flex-col lg:flex-row gap-10">
        <div class="flex-1">
          <div class="flex items-center justify-between mb-6 pb-4 border-b border-[var(--color-border)]">
            <span class="text-sm font-medium text-[var(--color-text-muted)]">Make any changes below?</span>
            <div class="flex gap-3">
              <%= cart_form.submit 'Update', class: 'btn btn-ghost text-[var(--color-text)] border-[var(--color-border)] text-xs' %>
              <%= cart_form.submit 'checkout', class: 'btn btn-dark text-xs' %>
            </div>
          </div>

          <div class="space-y-0">
            <% @cart_items.each_with_index do |item, i| %>
              <%= cart_form.fields_for :shopping_cart_items, item do |cart_items_form| %>
                <%= render partial: 'cart_item', locals: { cart_items_form: cart_items_form, item: item, i: i } %>
              <% end %>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>

    <% unless @saved_cart_items.empty? %>
      <div class="mt-12">
        <h2 class="text-xl font-medium mb-6" id="savedforlater">Saved for Later</h2>
        <div class="space-y-0">
          <%= render partial: '/shopping/cart_items/saved_items' %>
        </div>
      </div>
    <% end %>
  <% end %>
</div>
