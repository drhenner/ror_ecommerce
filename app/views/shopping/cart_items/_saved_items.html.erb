<% @saved_cart_items.each do |item| %>
  <div class="flex gap-5 py-5 border-b border-[var(--color-border)]">
    <div class="w-20 h-20 shrink-0 bg-[var(--color-highlight)] overflow-hidden">
      <%= image_tag item.variant.featured_image, alt: item.variant.product_name, class: "w-full h-full object-cover" %>
    </div>

    <div class="flex-1 min-w-0">
      <div class="flex justify-between items-start">
        <div>
          <h3 class="text-sm font-medium">
            <%= link_to item.variant.product_name, product_path(item.variant.product), class: "hover:text-[var(--color-accent)]" %>
          </h3>
          <% unless item.variant.brand_name.blank? %>
            <p class="text-xs text-[var(--color-text-muted)] mt-0.5"><%= item.variant.brand_name %></p>
          <% end %>
          <%= item.variant.display_stock_status('', '') %>
        </div>
        <p class="text-sm font-semibold"><%= number_to_currency item.price %></p>
      </div>

      <div class="flex items-center gap-3 mt-3 text-xs">
        <% unless item.variant.sold_out? %>
          <%= link_to 'Move to Bag',
              move_to_shopping_cart_item_path(item, variant_id: item.variant_id, item_type_id: ItemType::SHOPPING_CART_ID),
              data: { turbo_method: :put },
              class: 'text-[var(--color-accent)] hover:text-[var(--color-accent-light)] underline font-medium' %>
        <% end %>
        <%= link_to 'Remove', shopping_cart_item_path(item, variant_id: item.variant_id),
            data: { turbo_method: :delete },
            class: 'text-[var(--color-sale)] hover:text-red-700 underline' %>
      </div>
    </div>

    <p class="text-[10px] text-[var(--color-text-light)] whitespace-nowrap">
      Added <%= item.created_at.strftime(I18n.translate('time.formats.long_date')) %>
    </p>
  </div>
<% end %>
