<div class="py-10 max-w-md mx-auto">
  <h1 class="text-3xl font-normal mb-4" style="font-family: var(--font-display)"><%= I18n.t :reset_password_title %></h1>

  <p class="text-sm text-[var(--color-text-muted)] mb-6">
    <%= t :reset_password_text %>
  </p>

  <%= form_for(@user, url: customer_password_reset_path(@user)) do |f| %>
    <div class="space-y-4">
      <div>
        <%= f.label :email, class: 'block text-xs font-medium text-[var(--color-text-muted)] mb-1' %>
        <%= f.email_field :email, class: 'w-full border border-[var(--color-border)] px-3 py-2 text-sm' %>
      </div>
      <%= submit_tag 'Continue', class: 'btn btn-dark' %>
    </div>
  <% end %>
</div>
