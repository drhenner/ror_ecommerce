<div class="py-10">
  <% if @user_session.errors.any? %>
    <div class="bg-red-50 border border-red-200 text-red-800 px-5 py-4 mb-6 text-sm rounded max-w-2xl mx-auto">
      <h3 class="font-semibold mb-2"><%= pluralize(@user_session.errors.count, "error") %> prohibited you from logging in:</h3>
      <ul class="list-disc pl-5 space-y-1">
        <% @user_session.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% if @user.errors.any? %>
    <div class="bg-red-50 border border-red-200 text-red-800 px-5 py-4 mb-6 text-sm rounded max-w-2xl mx-auto">
      <ul class="list-disc pl-5 space-y-1">
        <% @user.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12">
    <%# Login %>
    <div id="login">
      <%= form_for @user_session, as: :user_session, url: user_sessions_path(@user_session) do |form| %>
        <h3 class="text-2xl font-normal mb-6" style="font-family: var(--font-display)">Log in</h3>
        <div class="space-y-4">
          <div>
            <%= form.label :email, 'Email', class: 'block text-xs font-medium text-[var(--color-text-muted)] mb-1' %>
            <%= form.email_field :email, autocomplete: 'off', autocapitalize: 'off', class: 'w-full border border-[var(--color-border)] px-3 py-2 text-sm' %>
          </div>
          <div>
            <%= form.label :password, 'Password', class: 'block text-xs font-medium text-[var(--color-text-muted)] mb-1' %>
            <%= form.password_field :password, autocomplete: 'off', autocapitalize: 'off', class: 'w-full border border-[var(--color-border)] px-3 py-2 text-sm' %>
          </div>
          <div class="flex items-center justify-between">
            <%= form.submit "Log In", class: 'btn btn-dark' %>
            <%= link_to 'Forgot password?', new_customer_password_reset_path, class: 'text-xs text-[var(--color-accent)] hover:underline' %>
          </div>
        </div>
      <% end %>
    </div>

    <%# Registration %>
    <div class="md:border-l md:border-[var(--color-border)] md:pl-12">
      <%= form_for @user, url: customer_registrations_path(@user) do |form| %>
        <h3 class="text-2xl font-normal mb-2" style="font-family: var(--font-display)">New to <%= site_name %>?</h3>
        <p class="text-sm text-[var(--color-text-muted)] mb-6">An account is required to checkout.</p>
        <div class="space-y-4">
          <div>
            <%= form.label :first_name, 'First name *', class: 'block text-xs font-medium text-[var(--color-text-muted)] mb-1' %>
            <%= form.text_field :first_name, class: 'w-full border border-[var(--color-border)] px-3 py-2 text-sm' %>
          </div>
          <div>
            <%= form.label :last_name, 'Last name *', class: 'block text-xs font-medium text-[var(--color-text-muted)] mb-1' %>
            <%= form.text_field :last_name, class: 'w-full border border-[var(--color-border)] px-3 py-2 text-sm' %>
          </div>
          <div>
            <%= form.label :email, 'Email *', class: 'block text-xs font-medium text-[var(--color-text-muted)] mb-1' %>
            <%= form.email_field :email, autocomplete: 'off', autocapitalize: 'off', class: 'w-full border border-[var(--color-border)] px-3 py-2 text-sm' %>
          </div>
          <div>
            <%= form.label :password, 'Password *', class: 'block text-xs font-medium text-[var(--color-text-muted)] mb-1' %>
            <%= form.password_field :password, autocomplete: 'off', autocapitalize: 'off', class: 'w-full border border-[var(--color-border)] px-3 py-2 text-sm' %>
          </div>
          <div>
            <%= form.label :password_confirmation, 'Confirm password *', class: 'block text-xs font-medium text-[var(--color-text-muted)] mb-1' %>
            <%= form.password_field :password_confirmation, autocomplete: 'off', autocapitalize: 'off', class: 'w-full border border-[var(--color-border)] px-3 py-2 text-sm' %>
          </div>
          <%= form.submit "Register", class: 'btn btn-accent' %>
        </div>
      <% end %>
    </div>
  </div>
</div>
